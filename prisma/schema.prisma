generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Education {
  id                 String  @id @default(uuid())
  institution        String
  course             String
  startYear          Int
  endYear            Int
}

model Experience {
  id            String   @id @default(uuid())
  company       String
  jobTitle      String
  startYear     Int
  endYear       Int
}
