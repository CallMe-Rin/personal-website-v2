generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Education {
  id                 String  @id @default(uuid())
  institution        String
  course             String
  startYear          Int
  endYear            Int
}

model Experience {
  id            String   @id @default(uuid())
  company       String
  jobTitle      String
  startYear     Int
  endYear       Int
}

model Project {
  id            String   @id @default(uuid())
  title         String
  description   String
  image         String
  github        String
}